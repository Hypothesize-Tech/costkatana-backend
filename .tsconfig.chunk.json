{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "src/modules/account-closure/**/*",
    "src/modules/activity/**/*",
    "src/modules/admin-discount/**/*",
    "src/modules/admin-dashboard/**/*",
    "src/modules/admin-ai-cost-monitoring/**/*",
    "src/modules/agent/**/*",
    "src/modules/agent-identity/**/*",
    "src/modules/agent-trace/**/*",
    "src/modules/alert/**/*",
    "src/modules/analytics/**/*",
    "src/modules/api-key/**/*",
    "src/modules/auth/**/*",
    "src/modules/auto-simulation/**/*",
    "src/modules/aws/**/*",
    "src/modules/backup/**/*",
    "src/modules/bedrock/**/*",
    "src/modules/billing/**/*",
    "src/modules/budget/**/*",
    "src/modules/cache/**/*"
  ],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*spec.ts",
    "**/*.test.ts",
    "**/__tests__/**",
    "**/integration.test.ts",
    "examples",
    "src/config/database.ts",
    "src/config/email.ts",
    "src/config/redis.ts",
    "src/config/telemetry.ts",
    "src/config/strategicPolicies.config.ts",
    "src/config/aws.ts",
    "src/config/sentry.ts",
    "src/config/agent-prompt-template.ts",
    "src/config/memoryVectorIndexes.ts",
    "src/config/search.config.ts",
    "src/config/mongodbMcp.config.ts",
    "src/config/mongoVectorIndex.ts"
  ]
}