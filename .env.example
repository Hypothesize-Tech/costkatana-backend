# Required
MONGODB_URI=mongodb://localhost:27017/costkatana
JWT_SECRET=your-jwt-secret-min-32-chars
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Optional - App
NODE_ENV=development
PORT=8000

# Optional - JWT
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Optional - Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional - Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Optional - Encryption
ENCRYPTION_KEY=default-encryption-key-change-this

# Optional - Redis (for future features: queues, cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=
REDIS_TLS=false

# Optional - Production MongoDB
# MONGODB_URI_PROD=mongodb://...
